{
  "version": 2,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/courts.js", "use": "@vercel/node" },
    { "src": "api/learn.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/courts", "dest": "/api/courts.js" },
    { "src": "/api/learn", "dest": "/api/learn.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
